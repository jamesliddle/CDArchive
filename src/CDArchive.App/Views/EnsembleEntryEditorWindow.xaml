<Window x:Class="CDArchive.App.Views.EnsembleEntryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Ensemble" Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6"
                    Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>

        <StackPanel>
            <TextBlock x:Name="EnsembleNameLabel" FontSize="14" FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="Members" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />

            <Grid Height="180">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Current members (left) -->
                <DockPanel Grid.Column="0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="Current" FontSize="10" Foreground="#888"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button Content="✕" Padding="6,1" FontSize="10" Margin="0,0,4,0"
                                ToolTip="Remove" Click="OnRemoveMemberClick" />
                        <Button Content="↑" Padding="6,1" FontSize="10" Margin="0,0,4,0"
                                Click="OnMoveMemberUpClick" />
                        <Button Content="↓" Padding="6,1" FontSize="10"
                                Click="OnMoveMemberDownClick" />
                    </StackPanel>
                    <ListBox x:Name="MembersList" FontSize="12"
                             BorderThickness="1" BorderBrush="#CCC" />
                </DockPanel>

                <!-- Arrow buttons -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                    <Button Content="&#x2190;" FontSize="14" Padding="6,2" Margin="0,2"
                            ToolTip="Add to members"
                            Click="OnAddMemberFromAvailableClick" />
                </StackPanel>

                <!-- Available instruments (right) -->
                <DockPanel Grid.Column="2">
                    <TextBlock DockPanel.Dock="Top" Text="Available" FontSize="10"
                               Foreground="#888" Margin="0,0,0,2" />
                    <ListBox x:Name="AvailableList" FontSize="12"
                             BorderThickness="1" BorderBrush="#CCC"
                             MouseDoubleClick="OnAvailableDoubleClick" />
                </DockPanel>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
