<UserControl x:Class="CDArchive.App.Views.CanonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
             xmlns:local="clr-namespace:CDArchive.Core.Models;assembly=CDArchive.Core"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CanonViewModel}"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#E8E8E8" Padding="10,6"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#555555" />
        </Border>

        <DockPanel Margin="5,10,5,5">

            <!-- ── Toolbar (two rows) ── -->
            <!--
                Column map (shared across both rows for alignment):
                  0 = Refresh icon   1 = gap
                  2 = New btn        3 = gap
                  4 = Delete btn     5 = gap
                  6 = Sort label     7 = Sort dropdown
                  8 = gap            9 = Filter label   10 = Filter box
            -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- 0: Refresh -->
                    <ColumnDefinition Width="8"    />  <!-- 1 -->
                    <ColumnDefinition Width="Auto" />  <!-- 2: New Composer / New Piece -->
                    <ColumnDefinition Width="8"    />  <!-- 3 -->
                    <ColumnDefinition Width="Auto" />  <!-- 4: Delete Composer / Delete Piece -->
                    <ColumnDefinition Width="16"   />  <!-- 5 -->
                    <ColumnDefinition Width="Auto" />  <!-- 6: Sort label -->
                    <ColumnDefinition Width="90"   />  <!-- 7: Sort dropdown -->
                    <ColumnDefinition Width="16"   />  <!-- 8 -->
                    <ColumnDefinition Width="Auto" />  <!-- 9: Filter label -->
                    <ColumnDefinition Width="150"  />  <!-- 10: Filter box -->
                </Grid.ColumnDefinitions>

                <!-- ── Row 0: Refresh · New Composer · Delete Composer · Sort Composers · Filter ── -->
                <Button Grid.Row="0" Grid.Column="0"
                        Content="↻" Padding="8,4" FontSize="14" Width="32" Height="28"
                        Command="{Binding LoadDataCommand}"
                        ToolTip="Reload all data from the database" />

                <Button Grid.Row="0" Grid.Column="2"
                        Content="New Composer" Padding="12,4" FontSize="12" Height="28"
                        Click="OnNewComposerClick" />

                <Button Grid.Row="0" Grid.Column="4"
                        Content="Delete Composer" Padding="12,4" FontSize="12" Height="28"
                        Foreground="#D32F2F"
                        Click="OnDeleteComposerClick" />

                <TextBlock Grid.Row="0" Grid.Column="6"
                           Text="Sort Composers:" FontSize="12" Foreground="#555"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Grid.Row="0" Grid.Column="7"
                          x:Name="ComposerSortCombo" FontSize="12" Height="23"
                          SelectedIndex="0"
                          SelectionChanged="OnComposerSortChanged">
                    <ComboBoxItem Content="Pieces" />
                    <ComboBoxItem Content="Name" />
                    <ComboBoxItem Content="Born" />
                    <ComboBoxItem Content="Died" />
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="9"
                           Text="Filter:" FontSize="12" Foreground="#555"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Row="0" Grid.Column="10"
                         Text="{Binding ComposerFilter, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="6,4"
                         TextChanged="OnFilterTextChanged" />

                <!-- ── Row 2: New Piece · Delete Piece · Sort Pieces ── -->
                <Button Grid.Row="2" Grid.Column="2"
                        x:Name="NewPieceButton" Content="New Piece"
                        Padding="12,4" FontSize="12" Height="28"
                        IsEnabled="False"
                        Click="OnNewPieceClick" />

                <Button Grid.Row="2" Grid.Column="4"
                        x:Name="DeletePieceButton" Content="Delete Piece"
                        Padding="12,4" FontSize="12" Height="28"
                        IsEnabled="False" Foreground="#D32F2F"
                        Click="OnDeletePieceClick" />

                <TextBlock Grid.Row="2" Grid.Column="6"
                           Text="Sort Pieces:" FontSize="12" Foreground="#555"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Grid.Row="2" Grid.Column="7"
                          x:Name="PieceSortCombo" FontSize="12" Height="23"
                          SelectedIndex="0"
                          SelectionChanged="OnPieceSortChanged">
                    <ComboBoxItem Content="Catalogue" />
                    <ComboBoxItem Content="Title" />
                    <ComboBoxItem Content="Category" />
                    <ComboBoxItem Content="Year" />
                </ComboBox>
            </Grid>

            <!-- ── Single unified tree panel ── -->
            <Border BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
                <DockPanel>

                    <!-- Composer column headers -->
                    <Grid DockPanel.Dock="Top" Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="19" />               <!-- expander space -->
                            <ColumnDefinition Width="65" MinWidth="50" /> <!-- Pieces -->
                            <ColumnDefinition Width="Auto" />             <!-- splitter -->
                            <ColumnDefinition Width="*" MinWidth="100" /> <!-- Name -->
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" x:Name="LHdrExpander" />

                        <Border Grid.Column="1" x:Name="LHdrPieces">
                            <TextBlock Text="Pieces" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555" TextAlignment="Right" Margin="0,0,8,0" />
                        </Border>

                        <GridSplitter Grid.Column="2" Width="4" Background="Transparent"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Cursor="SizeWE" />

                        <Border Grid.Column="3" x:Name="LHdrName">
                            <TextBlock Text="Name" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555" />
                        </Border>
                    </Grid>

                    <Border DockPanel.Dock="Top" BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1" Margin="0,0,0,2" />

                    <!-- ── Unified tree: Composer → Piece → Subpiece/Version ── -->
                    <TreeView x:Name="ComposerTree"
                              BorderThickness="0" Background="White"
                              FontSize="13"
                              VirtualizingStackPanel.IsVirtualizing="False"
                              SelectedItemChanged="OnComposerTreeSelectionChanged"
                              MouseRightButtonDown="OnTreeMouseRightButtonDown"
                              ContextMenuOpening="OnTreeContextMenuOpening"
                              KeyDown="OnTreeKeyDown">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="CtxEdit"
                                          Header="Edit" Click="OnContextEdit" />
                                <Separator />
                                <MenuItem x:Name="CtxExpandAll"
                                          Header="Expand all below"
                                          Click="OnContextExpandAll" />
                                <MenuItem x:Name="CtxCollapseAll"
                                          Header="Collapse all below"
                                          Click="OnContextCollapseAll" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.Template>
                            <ControlTemplate TargetType="TreeView">
                                <ScrollViewer Focusable="False" CanContentScroll="False"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto" Padding="0">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </TreeView.Template>
                        <TreeView.Resources>

                            <!-- Expander arrow (Path + one-way DataTrigger).
                                 A plain Path avoids the TwoWay ToggleButton.IsChecked ↔
                                 TreeViewItem.IsExpanded binding, which was fragile: WPF's
                                 IsEnabled-propagation during ShowDialog() owner-disable could
                                 briefly reset IsChecked, and the TwoWay path then collapsed
                                 every expanded row.  With a DataTrigger the arrow reflects
                                 IsExpanded read-only; toggling is done by OnExpanderBorderMouseDown. -->
                            <Style x:Key="ExpanderArrow" TargetType="Path">
                                <Setter Property="Data"                Value="M 0,0 L 6,4 L 0,8 Z" />
                                <Setter Property="Fill"                Value="#888" />
                                <Setter Property="Width"               Value="10" />
                                <Setter Property="Height"              Value="10" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment"   Value="Center" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded,
                                                     RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                 Value="True">
                                        <Setter Property="Data" Value="M 0,0 L 8,0 L 4,6 Z" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <!-- Custom TreeViewItem style -->
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border x:Name="Bd" Background="Transparent" Padding="0,1">
                                                    <ContentPresenter ContentSource="Header" />
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost"
                                                                Margin="19,0,0,0"
                                                                Visibility="Collapsed" />
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="True">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#E8F0FE" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F0F0F0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="MouseDoubleClick" Handler="OnTreeItemDoubleClick" />
                            </Style>

                            <!-- ── Level 1: Composer node ── -->
                            <HierarchicalDataTemplate DataType="{x:Type vm:ComposerTreeNode}"
                                                      ItemsSource="{Binding AllItems}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Border Width="19" Background="Transparent"
                                            MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                        <Path Style="{StaticResource ExpanderArrow}" />
                                    </Border>
                                    <Border Width="65">
                                        <TextBlock Text="{Binding Composer.PieceCount}"
                                                   TextAlignment="Right" Margin="0,0,8,0"
                                                   Foreground="#888888" FontSize="12" />
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Composer.Name}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Composer.LifeSpan}"
                                                   Foreground="#888888" FontSize="12"
                                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- ── Level 2: Piece node (expands to show subpieces) ── -->
                            <HierarchicalDataTemplate DataType="{x:Type local:CanonPiece}"
                                                      ItemsSource="{Binding TreeChildren}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <!--
                                        The TreeViewItem indent is 19 px (= LHdrExpander width).
                                        We mirror the LHdrPieces column with a same-width Border so
                                        the title lands exactly on the Name column.  The expander
                                        sits right-aligned inside that placeholder; 4 px after it
                                        matches the GridSplitter between the Pieces and Name columns.
                                    -->
                                    <Border Width="65">
                                        <Grid Width="16" Height="16" HorizontalAlignment="Right"
                                              Background="Transparent"
                                              MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                            <Path Style="{StaticResource ExpanderArrow}"
                                                  Visibility="{Binding HasTreeChildren,
                                                      Converter={StaticResource BoolToVisConverter}}" />
                                        </Grid>
                                    </Border>
                                    <Border Width="4" /> <!-- matches the GridSplitter column -->
                                    <TextBlock Text="{Binding DisplayTitleShort}"
                                               FontSize="12" Foreground="#333">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="600">
                                                <TextBlock Text="{Binding ToolTipText}"
                                                           TextWrapping="Wrap" FontSize="13" />
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Catalog}"
                                               FontSize="11" Foreground="#888"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- ── Level 3: Subpiece / movement node ── -->
                            <!--
                                The TreeViewItem style indents every level's children by 19 px.
                                By mirroring the same LHdrPieces border + 4 px splitter gap used
                                in the piece template, each deeper level's title lands exactly
                                19 px further right than its parent's title, giving a natural
                                progressive indent that also tracks the Pieces column splitter.
                            -->
                            <HierarchicalDataTemplate DataType="{x:Type local:SubpieceDisplayNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Border Width="65">
                                        <Grid Width="16" Height="16" HorizontalAlignment="Right"
                                              Background="Transparent"
                                              MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                            <Path Style="{StaticResource ExpanderArrow}"
                                                  Visibility="{Binding HasChildren,
                                                      Converter={StaticResource BoolToVisConverter}}" />
                                        </Grid>
                                    </Border>
                                    <Border Width="4" />
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               FontSize="12" Foreground="#444">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="600">
                                                <TextBlock Text="{Binding Piece.ToolTipText}"
                                                           TextWrapping="Wrap" FontSize="13" />
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Piece.Category}"
                                               FontSize="11" Foreground="#999"
                                               Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- ── Level 3 (alt): Original node — represents the piece's own version ── -->
                            <HierarchicalDataTemplate DataType="{x:Type local:PieceOriginalNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Border Width="65">
                                        <Grid Width="16" Height="16" HorizontalAlignment="Right"
                                              Background="Transparent"
                                              MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                            <Path Style="{StaticResource ExpanderArrow}"
                                                  Visibility="{Binding HasChildren,
                                                      Converter={StaticResource BoolToVisConverter}}" />
                                        </Grid>
                                    </Border>
                                    <Border Width="4" />
                                    <TextBlock Text="Original"
                                               FontSize="12" Foreground="#555" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- ── Level 3 (alt): Version node ── -->
                            <HierarchicalDataTemplate DataType="{x:Type local:VersionDisplayNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Border Width="65">
                                        <Grid Width="16" Height="16" HorizontalAlignment="Right"
                                              Background="Transparent"
                                              MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                            <Path Style="{StaticResource ExpanderArrow}"
                                                  Visibility="{Binding HasSubpieces,
                                                      Converter={StaticResource BoolToVisConverter}}" />
                                        </Grid>
                                    </Border>
                                    <Border Width="4" />
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               FontSize="12" Foreground="#666" FontStyle="Italic" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- ── Contributed works: role + composer group header ── -->
                            <HierarchicalDataTemplate DataType="{x:Type local:ContributedRoleGroupNode}"
                                                      ItemsSource="{Binding Pieces}">
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,1">
                                    <Border Width="65">
                                        <Grid Width="16" Height="16" HorizontalAlignment="Right"
                                              Background="Transparent"
                                              MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                            <Path Style="{StaticResource ExpanderArrow}" />
                                        </Grid>
                                    </Border>
                                    <Border Width="4" />
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               FontSize="12" Foreground="#777" FontStyle="Italic" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- ── Contributed works: piece node under a role group ── -->
                            <HierarchicalDataTemplate DataType="{x:Type local:ContributedPieceNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Border Width="65">
                                        <Grid Width="16" Height="16" HorizontalAlignment="Right"
                                              Background="Transparent"
                                              MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                            <Path Style="{StaticResource ExpanderArrow}"
                                                  Visibility="{Binding HasChildren,
                                                      Converter={StaticResource BoolToVisConverter}}" />
                                        </Grid>
                                    </Border>
                                    <Border Width="4" />
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               FontSize="12" Foreground="#333">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="600">
                                                <TextBlock Text="{Binding Piece.ToolTipText}"
                                                           TextWrapping="Wrap" FontSize="13" />
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Catalog}"
                                               FontSize="11" Foreground="#888"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                        </TreeView.Resources>
                    </TreeView>

                </DockPanel>
            </Border>

        </DockPanel>
    </DockPanel>
</UserControl>
