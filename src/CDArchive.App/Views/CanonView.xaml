<UserControl x:Class="CDArchive.App.Views.CanonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CanonViewModel}"
             Loaded="OnLoaded">

    <DockPanel>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#E8E8E8" Padding="10,6"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#555555" />
        </Border>

        <DockPanel Margin="5,10,5,5">
            <!-- Toolbar: Filter + Buttons -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Pieces" Padding="12,4" Margin="8,0,0,0" FontSize="12"
                            x:Name="PiecesButton" Click="OnPiecesClick"
                            IsEnabled="False" />
                    <Button Content="New Composer" Padding="12,4" Margin="8,0,0,0" FontSize="12"
                            Click="OnNewComposerClick" />
                    <Button Content="Delete" Padding="12,4" Margin="8,0,0,0" FontSize="12"
                            Foreground="#D32F2F"
                            Command="{Binding DeleteComposerCommand}" />
                </StackPanel>
                <TextBlock Text="Filter:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="12" Foreground="#555" />
                <TextBox Text="{Binding ComposerFilter, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="6,4"
                         TextChanged="OnFilterTextChanged" />
            </DockPanel>

            <!-- Column headers + composer list -->
            <Border BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
                <DockPanel>
                    <!-- Column headers with GridSplitters -->
                    <Grid DockPanel.Dock="Top" Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" MinWidth="35" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="100" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="75" MinWidth="45" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="75" MinWidth="45" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="HdrPieces" Cursor="Hand"
                                Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                                Tag="Pieces">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                                <TextBlock Text="Pieces" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock x:Name="SortPieces" FontSize="10" Margin="3,0,0,0"
                                           Foreground="#999" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Cursor="SizeWE" />
                        <Border Grid.Column="2" x:Name="HdrName" Cursor="Hand"
                                Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                                Tag="Name">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Name" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock x:Name="SortName" FontSize="10" Margin="3,0,0,0"
                                           Foreground="#999" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <GridSplitter Grid.Column="3" Width="4" Background="Transparent"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Cursor="SizeWE" />
                        <Border Grid.Column="4" x:Name="HdrBirth" Cursor="Hand"
                                Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                                Tag="Birth">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Born" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock x:Name="SortBirth" FontSize="10" Margin="3,0,0,0"
                                           Foreground="#999" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <GridSplitter Grid.Column="5" Width="4" Background="Transparent"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Cursor="SizeWE" />
                        <Border Grid.Column="6" x:Name="HdrDeath" Cursor="Hand"
                                Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                                Tag="Death">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Died" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555" />
                                <TextBlock x:Name="SortDeath" FontSize="10" Margin="3,0,0,0"
                                           Foreground="#999" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border DockPanel.Dock="Top" BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1" Margin="0,0,0,2" />

                    <!-- Composer list -->
                    <ListBox x:Name="ComposerList"
                             ItemsSource="{Binding FilteredComposers}"
                             SelectedItem="{Binding SelectedComposer}"
                             FontSize="13"
                             BorderThickness="0" Background="White"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="OnComposerDoubleClick"
                             SelectionChanged="OnComposerSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0,2" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="{Binding ActualWidth, ElementName=HdrPieces}">
                                        <TextBlock Text="{Binding PieceCount}"
                                                   Foreground="#888888" FontSize="12"
                                                   TextAlignment="Right" Margin="0,0,8,0" />
                                    </Border>
                                    <Border Width="{Binding ActualWidth, ElementName=HdrName}">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Border Width="{Binding ActualWidth, ElementName=HdrBirth}">
                                        <TextBlock Text="{Binding BirthYear}"
                                                   Foreground="#888888" FontSize="12" />
                                    </Border>
                                    <Border Width="{Binding ActualWidth, ElementName=HdrDeath}">
                                        <TextBlock Text="{Binding DeathYear}"
                                                   Foreground="#888888" FontSize="12" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </DockPanel>
    </DockPanel>
</UserControl>
