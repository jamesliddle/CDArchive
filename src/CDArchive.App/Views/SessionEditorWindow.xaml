<Window x:Class="CDArchive.App.Views.SessionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recording Session"
        Width="400" Height="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <DockPanel Margin="15">

        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6" Margin="8,0,0,0"
                    IsCancel="True" />
        </StackPanel>

        <!-- Fields -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Dates -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Dates:"
                       VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="DatesBox"
                     FontSize="13" Padding="4,3" Margin="0,0,0,8" />

            <!-- Venue -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Venue:"
                       VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="VenueBox"
                     FontSize="13" Padding="4,3" Margin="0,0,0,8" />

            <!-- City -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="City:"
                       VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="CityBox"
                     FontSize="13" Padding="4,3" Margin="0,0,0,8" />

            <!-- Country -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Country:"
                       VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="CountryBox"
                     FontSize="13" Padding="4,3" Margin="0,0,0,8" />

            <!-- Engineers -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Engineers:"
                       VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="EngineersBox"
                     FontSize="13" Padding="4,3" Margin="0,0,0,8"
                     ToolTip="Separate multiple names with a comma" />

            <!-- Producers -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Producers:"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="ProducersBox"
                     FontSize="13" Padding="4,3"
                     ToolTip="Separate multiple names with a comma" />

        </Grid>
    </DockPanel>
</Window>
