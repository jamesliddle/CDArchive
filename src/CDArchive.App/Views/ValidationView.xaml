<UserControl x:Class="CDArchive.App.Views.ValidationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
             xmlns:converters="clr-namespace:CDArchive.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ValidationViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:ValidationSeverityToColorConverter x:Key="SeverityToColorConverter" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Top Controls -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
            <Button Content="Validate Archive"
                    Command="{Binding ValidateCommand}"
                    FontSize="14"
                    Padding="20,8"
                    HorizontalAlignment="Left"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,12" />

            <!-- Progress Bar -->
            <ProgressBar Value="{Binding Progress}"
                         Minimum="0"
                         Maximum="100"
                         Height="20"
                         Foreground="#007ACC"
                         Background="#E0E0E0"
                         BorderThickness="0" />
        </StackPanel>

        <!-- Status Message -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   FontSize="13"
                   Foreground="#555555"
                   Margin="0,10,0,0" />

        <!-- Validation Results DataGrid -->
        <DataGrid ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  FontSize="13"
                  Margin="0,12,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Album"
                                    Binding="{Binding AlbumName}"
                                    Width="200" />
                <DataGridTextColumn Header="Issues"
                                    Binding="{Binding Issues.Count}"
                                    Width="80" />
            </DataGrid.Columns>
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <ItemsControl ItemsSource="{Binding Issues}"
                                  Margin="30,5,10,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="{Binding Severity}"
                                               FontWeight="SemiBold"
                                               Width="70"
                                               Foreground="{Binding Severity, Converter={StaticResource SeverityToColorConverter}}" />
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="#333333"
                                               Width="350"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Path}"
                                               Foreground="#888888"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>
    </DockPanel>
</UserControl>
