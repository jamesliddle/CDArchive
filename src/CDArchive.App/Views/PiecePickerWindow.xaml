<Window x:Class="CDArchive.App.Views.PiecePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CDArchive.App.Views"
        Title="Select Piece or Movement"
        Width="820" Height="640"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="OkButton" Content="Select" Width="80" Padding="0,6"
                    IsDefault="True" IsEnabled="False" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6" Margin="8,0,0,0"
                    IsCancel="True" />
        </StackPanel>

        <!-- Filter / sort toolbar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />   <!-- "Composer:" -->
                <ColumnDefinition Width="180" />    <!-- composer combo -->
                <ColumnDefinition Width="14" />     <!-- gap -->
                <ColumnDefinition Width="Auto" />   <!-- "Sort:" -->
                <ColumnDefinition Width="110" />    <!-- sort combo -->
                <ColumnDefinition Width="14" />     <!-- gap -->
                <ColumnDefinition Width="Auto" />   <!-- "Search:" -->
                <ColumnDefinition Width="*" />      <!-- search box -->
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Composer:" VerticalAlignment="Center"
                       FontSize="13" Foreground="#555" Margin="0,0,6,0" />
            <ComboBox Grid.Column="1" x:Name="ComposerBox" FontSize="13"
                      SelectionChanged="OnComposerFilterChanged" />

            <TextBlock Grid.Column="3" Text="Sort:" VerticalAlignment="Center"
                       FontSize="13" Foreground="#555" Margin="0,0,6,0" />
            <ComboBox Grid.Column="4" x:Name="SortBox" FontSize="13"
                      SelectionChanged="OnSortChanged">
                <ComboBoxItem Content="Catalogue" IsSelected="True" />
                <ComboBoxItem Content="Title" />
                <ComboBoxItem Content="Category" />
                <ComboBoxItem Content="Year" />
            </ComboBox>

            <TextBlock Grid.Column="6" Text="Search:" VerticalAlignment="Center"
                       FontSize="13" Foreground="#555" Margin="0,0,6,0" />
            <TextBox Grid.Column="7" x:Name="SearchBox" FontSize="13" Padding="4,4"
                     VerticalContentAlignment="Center"
                     TextChanged="OnSearchChanged" />
        </Grid>

        <!-- Hint -->
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6"
                   FontSize="11" Foreground="#888" TextWrapping="Wrap"
                   Text="Select a piece for a whole-work link, or expand to select a specific movement or version." />

        <!-- Tree -->
        <Border BorderThickness="1" BorderBrush="#CCC" Background="White">
            <TreeView x:Name="PieceTree"
                      BorderThickness="0" Background="White"
                      FontSize="13"
                      VirtualizingStackPanel.IsVirtualizing="False"
                      SelectedItemChanged="OnTreeSelectionChanged"
                      MouseDoubleClick="OnTreeDoubleClick"
                      KeyDown="OnTreeKeyDown">

                <TreeView.Resources>

                    <!-- Expander arrow — Path + one-way DataTrigger on IsExpanded
                         (same pattern as CanonView: avoids the fragile TwoWay
                         ToggleButton.IsChecked ↔ TreeViewItem.IsExpanded binding). -->
                    <Style x:Key="ExpanderArrow" TargetType="Path">
                        <Setter Property="Data"                Value="M 0,0 L 6,4 L 0,8 Z" />
                        <Setter Property="Fill"                Value="#888" />
                        <Setter Property="Width"               Value="10" />
                        <Setter Property="Height"              Value="10" />
                        <Setter Property="HorizontalAlignment" Value="Center" />
                        <Setter Property="VerticalAlignment"   Value="Center" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded,
                                             RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                         Value="True">
                                <Setter Property="Data" Value="M 0,0 L 8,0 L 4,6 Z" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>

                    <!-- TreeViewItem style: bind IsExpanded / IsSelected to the
                         PickerTreeNode so search-driven auto-expand and
                         programmatic selection work. Hide the expander column
                         when the node has no children. -->
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <StackPanel>
                                        <Border x:Name="Bd" Background="Transparent" Padding="0,1">
                                            <ContentPresenter ContentSource="Header" />
                                        </Border>
                                        <ItemsPresenter x:Name="ItemsHost"
                                                        Margin="19,0,0,0"
                                                        Visibility="Collapsed" />
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="True">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E8F0FE" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F0F0F0" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Level 1: Composer -->
                    <HierarchicalDataTemplate DataType="{x:Type views:PickerComposerNode}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Border Width="19" Background="Transparent"
                                    MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                <Path Style="{StaticResource ExpanderArrow}" />
                            </Border>
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LifeSpan}"
                                       Foreground="#888" FontSize="12"
                                       Margin="6,0,0,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PieceCountLabel}"
                                       Foreground="#AAA" FontSize="11"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Level 2: Piece -->
                    <HierarchicalDataTemplate DataType="{x:Type views:PickerPieceNode}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <Grid Width="19" Height="16"
                                  Background="Transparent"
                                  MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                <Path Style="{StaticResource ExpanderArrow}"
                                      Visibility="{Binding HasChildren,
                                                   Converter={StaticResource BoolToVis}}" />
                            </Grid>
                            <TextBlock Text="{Binding DisplayTitle}"
                                       FontSize="13" Foreground="#333">
                                <TextBlock.ToolTip>
                                    <ToolTip MaxWidth="600">
                                        <TextBlock Text="{Binding ToolTipText}"
                                                   TextWrapping="Wrap" FontSize="13" />
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock Text="{Binding Catalog}"
                                       FontSize="11" Foreground="#888"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Level 3: Original (piece own version, shown when piece has alternative versions) -->
                    <HierarchicalDataTemplate DataType="{x:Type views:PickerOriginalNode}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <Grid Width="19" Height="16"
                                  Background="Transparent"
                                  MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                <Path Style="{StaticResource ExpanderArrow}"
                                      Visibility="{Binding HasChildren,
                                                   Converter={StaticResource BoolToVis}}" />
                            </Grid>
                            <TextBlock Text="Original" FontSize="13" Foreground="#555" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Level 3: Version -->
                    <HierarchicalDataTemplate DataType="{x:Type views:PickerVersionNode}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <Grid Width="19" Height="16"
                                  Background="Transparent"
                                  MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                <Path Style="{StaticResource ExpanderArrow}"
                                      Visibility="{Binding HasChildren,
                                                   Converter={StaticResource BoolToVis}}" />
                            </Grid>
                            <TextBlock Text="{Binding DisplayTitle}"
                                       FontSize="13" Foreground="#4472C4" FontStyle="Italic" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Level 4+: Subpiece / movement -->
                    <HierarchicalDataTemplate DataType="{x:Type views:PickerSubpieceNode}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <Grid Width="19" Height="16"
                                  Background="Transparent"
                                  MouseLeftButtonDown="OnExpanderBorderMouseDown">
                                <Path Style="{StaticResource ExpanderArrow}"
                                      Visibility="{Binding HasChildren,
                                                   Converter={StaticResource BoolToVis}}" />
                            </Grid>
                            <TextBlock Text="{Binding DisplayTitle}"
                                       FontSize="12" Foreground="#444" />
                        </StackPanel>
                    </HierarchicalDataTemplate>

                </TreeView.Resources>
            </TreeView>
        </Border>

    </DockPanel>
</Window>
