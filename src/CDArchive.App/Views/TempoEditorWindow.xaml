<Window x:Class="CDArchive.App.Views.TempoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Tempo" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Number" VerticalAlignment="Center"
                       Foreground="#555" FontSize="12" Margin="0,0,8,0" />
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NumberBox"
                       FontSize="13" Padding="4,3" Margin="0,3"
                       Width="60" HorizontalAlignment="Left" />

            <TextBlock Grid.Row="1" Text="Description" VerticalAlignment="Center"
                       Foreground="#555" FontSize="12" Margin="0,0,8,0" />
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="DescriptionBox"
                       FontSize="13" Padding="4,3" Margin="0,3"
                       TextWrapping="Wrap" AcceptsReturn="False"
                       MinHeight="26" />
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6"
                    Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
