<Window x:Class="CDArchive.App.Views.VersionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Version" Width="560" Height="685"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="IsEditable" Value="True" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6"
                    Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
          <StackPanel>
            <!-- Fields grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Description" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="DescriptionBox"
                           ToolTip="Label identifying this version, e.g. 'Original', 'arr. for string quartet'" />

                <TextBlock Grid.Row="1" Text="Form" Style="{StaticResource FieldLabel}" />
                <ComboBox  Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldCombo}"
                           x:Name="FormCombo" />

                <TextBlock Grid.Row="2" Text="Title" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="TitleBox" />

                <TextBlock Grid.Row="3" Text="Title (English)" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="TitleEnglishBox"
                           ToolTip="English translation of a non-English title" />

                <TextBlock Grid.Row="4" Text="Subtitle" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="SubtitleBox" />

                <TextBlock Grid.Row="5" Text="Nickname" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="5" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="NicknameBox" />

                <TextBlock Grid.Row="6" Text="Number" Style="{StaticResource FieldLabel}" />
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="NumberBox" Style="{StaticResource FieldBox}" Width="60" />
                    <TextBlock Text="Music No." VerticalAlignment="Center"
                               Foreground="#555" FontSize="12" Margin="14,0,8,0" />
                    <TextBox x:Name="MusicNumberBox" Style="{StaticResource FieldBox}" Width="60"
                             ToolTip="Visible number shown to the user, independent of the ordering sequence number." />
                </StackPanel>

                <TextBlock Grid.Row="7" Text="Key Tonality" Style="{StaticResource FieldLabel}" />
                <ComboBox  Grid.Row="7" Grid.Column="1" Style="{StaticResource FieldCombo}"
                           x:Name="KeyTonalityCombo" Width="120" HorizontalAlignment="Left" />

                <TextBlock Grid.Row="8" Text="Key Mode" Style="{StaticResource FieldLabel}" />
                <ComboBox  Grid.Row="8" Grid.Column="1" Width="120" HorizontalAlignment="Left"
                           Margin="0,3" Padding="4,4" FontSize="13"
                           x:Name="KeyModeCombo">
                    <ComboBoxItem Content="" />
                    <ComboBoxItem Content="major" />
                    <ComboBoxItem Content="minor" />
                </ComboBox>

                <!-- Catalogue — supports multiple catalog systems -->
                <TextBlock Grid.Row="9" Text="Catalogue" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Top" Margin="0,6,8,0" />
                <Border Grid.Row="9" Grid.Column="1" Margin="0,3"
                        BorderThickness="1" BorderBrush="#CCC">
                    <StackPanel>
                        <DockPanel MinHeight="20" MaxHeight="72">
                            <Button DockPanel.Dock="Right" Content="✕" Padding="6,3" FontSize="11"
                                    VerticalAlignment="Top" Margin="2"
                                    ToolTip="Remove selected entry"
                                    Click="OnRemoveCatalogClick" />
                            <ListBox x:Name="CatalogList" FontSize="12" BorderThickness="0" />
                        </DockPanel>
                        <Border BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" />
                        <Grid Margin="4,4,4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Style="{StaticResource FieldCombo}"
                                      x:Name="CatalogPrefixCombo" Margin="0,0,4,0" />
                            <TextBox  Grid.Column="1" Style="{StaticResource FieldBox}"
                                      x:Name="CatalogNumberBox" />
                            <Button   Grid.Column="2" Content="Add" Padding="8,3" FontSize="11"
                                      Margin="4,3,0,3" Click="OnAddCatalogClick" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="10" Text="Category" Style="{StaticResource FieldLabel}" />
                <ComboBox  Grid.Row="10" Grid.Column="1" Style="{StaticResource FieldCombo}"
                           x:Name="CategoryCombo" Width="160" HorizontalAlignment="Left" />

                <TextBlock Grid.Row="11" Text="Pub. Year" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="11" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="PubYearBox" Width="80" HorizontalAlignment="Left" />

                <TextBlock Grid.Row="12" Text="Comp. Years" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="12" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="CompYearsBox"
                           ToolTip="Year(s) of composition, e.g. 1803, 1803-1804, c1893" />

                <TextBlock Grid.Row="13" Text="Instrumentation" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Top" Margin="0,6,8,0" />
                <Grid Grid.Row="13" Grid.Column="1" Margin="0,3" Height="160">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="Piece" FontSize="10" Foreground="#888"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Button Content="Edit" Padding="6,1" FontSize="10" Margin="0,0,4,0"
                                    Click="OnEditInstrumentClick" />
                            <Button Content="✕" Padding="6,1" FontSize="10" Margin="0,0,4,0"
                                    ToolTip="Remove" Click="OnRemoveInstrumentClick" />
                            <Button Content="↑" Padding="6,1" FontSize="10" Margin="0,0,4,0"
                                    Click="OnMoveInstrumentUpClick" />
                            <Button Content="↓" Padding="6,1" FontSize="10"
                                    Click="OnMoveInstrumentDownClick" />
                        </StackPanel>
                        <ListBox x:Name="InstrumentsList" FontSize="12"
                                 BorderThickness="1" BorderBrush="#CCC"
                                 MouseDoubleClick="OnInstrumentDoubleClick" />
                    </DockPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                        <Button Content="&#x2190;" FontSize="14" Padding="6,2" Margin="0,2"
                                ToolTip="Add to piece" Click="OnAddFromAvailableClick" />
                        <Button Content="&#x2192;" FontSize="14" Padding="6,2" Margin="0,2"
                                ToolTip="Remove from piece" Click="OnRemoveInstrumentClick" />
                    </StackPanel>
                    <DockPanel Grid.Column="2">
                        <TextBlock DockPanel.Dock="Top" Text="Available" FontSize="10"
                                   Foreground="#888" Margin="0,0,0,2" />
                        <ListBox x:Name="AvailableInstrumentsList" FontSize="12"
                                 BorderThickness="1" BorderBrush="#CCC"
                                 MouseDoubleClick="OnAvailableInstrumentDoubleClick" />
                    </DockPanel>
                </Grid>

                <TextBlock Grid.Row="14" Text="First Line" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="14" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="FirstLineBox"
                           ToolTip="Opening line of text for vocal numbers" />

                <!-- Text Author — supports multiple names -->
                <TextBlock Grid.Row="15" Text="Text Author" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Top" Margin="0,6,8,0" />
                <Border Grid.Row="15" Grid.Column="1" Margin="0,3"
                        BorderThickness="1" BorderBrush="#CCC">
                    <StackPanel>
                        <DockPanel MinHeight="20" MaxHeight="72">
                            <Button DockPanel.Dock="Right" Content="✕" Padding="6,3" FontSize="11"
                                    VerticalAlignment="Top" Margin="2"
                                    ToolTip="Remove selected text author"
                                    Click="OnRemoveTextAuthorClick" />
                            <ListBox x:Name="TextAuthorList" FontSize="12" BorderThickness="0" />
                        </DockPanel>
                        <Border BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" />
                        <DockPanel Margin="4,4,4,4">
                            <Button DockPanel.Dock="Right" Content="Add" Padding="8,3" FontSize="11"
                                    Margin="4,0,0,0" Click="OnAddTextAuthorClick" />
                            <TextBox x:Name="TextAuthorEntryBox" FontSize="12" Padding="4,3"
                                     ToolTip="Type a text author name and click Add" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Roles — list of character names -->
                <TextBlock Grid.Row="16" Text="Roles" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Top" Margin="0,6,8,0" />
                <Border Grid.Row="16" Grid.Column="1" Margin="0,3"
                        BorderThickness="1" BorderBrush="#CCC">
                    <StackPanel>
                        <DockPanel MinHeight="20" MaxHeight="72">
                            <Button DockPanel.Dock="Right" Content="✕" Padding="6,3" FontSize="11"
                                    VerticalAlignment="Top" Margin="2"
                                    ToolTip="Remove selected role"
                                    Click="OnRemoveRoleClick" />
                            <ListBox x:Name="RoleList" FontSize="12" BorderThickness="0" />
                        </DockPanel>
                        <Border BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" />
                        <DockPanel Margin="4,4,4,4">
                            <Button DockPanel.Dock="Right" Content="Add" Padding="8,3" FontSize="11"
                                    Margin="4,0,0,0" Click="OnAddRoleClick" />
                            <TextBox x:Name="RoleEntryBox" FontSize="12" Padding="4,3"
                                     ToolTip="Type a character name and click Add" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tempo Indications section -->
            <TextBlock Text="Tempo Indications" FontWeight="SemiBold" FontSize="12"
                       Foreground="#555" Margin="0,14,0,6" />

            <Border BorderThickness="1" BorderBrush="#D0D0D0" Background="#FAFAFA"
                    Padding="6" MinHeight="80">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Margin="6,0,0,0">
                        <Button Content="Add"    Padding="8,3" FontSize="11" Margin="0,0,0,0" Click="OnAddTempoClick" />
                        <Button Content="Edit"   Padding="8,3" FontSize="11" Margin="0,4,0,0" Click="OnEditTempoClick" />
                        <Button Content="Remove" Padding="8,3" FontSize="11" Margin="0,4,0,0" Click="OnRemoveTempoClick" />
                        <Border Height="8" />
                        <Button Content="Up"     Padding="8,3" FontSize="11" Margin="0,0,0,0" Click="OnMoveTempoUpClick" />
                        <Button Content="Down"   Padding="8,3" FontSize="11" Margin="0,4,0,0" Click="OnMoveTempoDownClick" />
                    </StackPanel>
                    <ListBox x:Name="TempoList" FontSize="12" MinHeight="60"
                             BorderThickness="1" BorderBrush="#CCC"
                             MouseDoubleClick="OnTempoDoubleClick" />
                </DockPanel>
            </Border>

            <!-- Subpieces section -->
            <DockPanel Margin="0,14,0,6" LastChildFill="False">
                <TextBlock Text="Movements / Subpieces" FontWeight="SemiBold" FontSize="12"
                           Foreground="#555" VerticalAlignment="Center" />
                <CheckBox x:Name="NumberedSubpiecesCheck" Content="Numbered" FontSize="11"
                          Foreground="#666" Margin="14,0,0,0" VerticalAlignment="Center"
                          Checked="OnNumberedSubpiecesChanged"
                          Unchecked="OnNumberedSubpiecesChanged" />
                <TextBlock Text="Start:" FontSize="11" Foreground="#666"
                           Margin="12,0,4,0" VerticalAlignment="Center" />
                <TextBox x:Name="SubpiecesStartBox" Width="36" FontSize="11" Padding="2,1"
                         VerticalAlignment="Center" Margin="0,2"
                         TextChanged="OnSubpiecesStartChanged" />
            </DockPanel>

            <Border BorderThickness="1" BorderBrush="#D0D0D0" Background="#FAFAFA"
                    Padding="6" MinHeight="80" Height="160">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Margin="6,0,0,0">
                        <Button Content="Add"    Padding="8,3" FontSize="11" Margin="0,0,0,0" Click="OnAddSubpieceClick" />
                        <Button Content="Edit"   Padding="8,3" FontSize="11" Margin="0,4,0,0" Click="OnEditSubpieceClick" />
                        <Button Content="Remove" Padding="8,3" FontSize="11" Margin="0,4,0,0" Click="OnRemoveSubpieceClick" />
                        <Border Height="8" />
                        <Button Content="Up"     Padding="8,3" FontSize="11" Margin="0,0,0,0" Click="OnMoveSubpieceUpClick" />
                        <Button Content="Down"   Padding="8,3" FontSize="11" Margin="0,4,0,0" Click="OnMoveSubpieceDownClick" />
                    </StackPanel>
                    <ListBox x:Name="SubpieceList" FontSize="12"
                             BorderThickness="1" BorderBrush="#CCC"
                             MouseDoubleClick="OnSubpieceDoubleClick" />
                </DockPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
