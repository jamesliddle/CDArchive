<UserControl x:Class="CDArchive.App.Views.ArchiveBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
             xmlns:converters="clr-namespace:CDArchive.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ArchiveBrowserViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Top Controls -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Scan Archive"
                    Command="{Binding ScanCommand}"
                    FontSize="14"
                    Padding="20,8"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand" />

            <TextBlock Text="Scanning..."
                       FontSize="14"
                       Foreground="#555555"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"
                       Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- Status Message -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   FontSize="13"
                   Foreground="#555555"
                   Margin="0,10,0,0" />

        <!-- Albums DataGrid -->
        <DataGrid ItemsSource="{Binding Albums}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Disc Count"
                                    Binding="{Binding DiscCount}"
                                    Width="100" />
                <DataGridTextColumn Header="Full Path"
                                    Binding="{Binding FullPath}"
                                    Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
