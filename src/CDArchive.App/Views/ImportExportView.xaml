<UserControl x:Class="CDArchive.App.Views.ImportExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ImportExportViewModel}">

    <StackPanel MaxWidth="520" HorizontalAlignment="Left">

        <!-- Export section -->
        <TextBlock Text="Export" FontSize="15" FontWeight="SemiBold"
                   Foreground="#333" Margin="0,0,0,8" />
        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="12" Margin="0,0,0,12">
            Save the current data to a JSON file of your choosing.
            The default filename and location match the canonical data files.
        </TextBlock>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="Export Composers…" Width="160" Padding="0,7"
                    Command="{Binding ExportComposersCommand}" />
            <Button Content="Export Pieces…" Width="160" Padding="0,7"
                    Margin="10,0,0,0"
                    Command="{Binding ExportPiecesCommand}" />
        </StackPanel>

        <Button Content="Normalize JSON Files" Width="200" Padding="0,7"
                HorizontalAlignment="Left" Margin="0,6,0,0"
                Command="{Binding NormalizeJsonCommand}"
                ToolTip="Re-read and re-write the canonical JSON files, applying standard sort order and formatting" />

        <!-- Separator -->
        <Separator Margin="0,20,0,16" />

        <!-- Import section -->
        <TextBlock Text="Import" FontSize="15" FontWeight="SemiBold"
                   Foreground="#333" Margin="0,0,0,8" />
        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="12" Margin="0,0,0,12">
            Merge records from a JSON file into the current data.
            Only records not already present will be added — existing records are never modified.
            Composers are matched by name; pieces are matched by composer + title.
        </TextBlock>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="Import Composers…" Width="160" Padding="0,7"
                    Command="{Binding ImportComposersCommand}" />
            <Button Content="Import Pieces…" Width="160" Padding="0,7"
                    Margin="10,0,0,0"
                    Command="{Binding ImportPiecesCommand}" />
        </StackPanel>

        <!-- Separator -->
        <Separator Margin="0,20,0,16" />

        <!-- Restore section -->
        <TextBlock Text="Restore" FontSize="15" FontWeight="SemiBold"
                   Foreground="#333" Margin="0,0,0,8" />
        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="12" Margin="0,0,0,12">
            Overwrite the canonical data files with files you select.
            Use this to restore from a backup. The current data will be replaced.
        </TextBlock>

        <Button Content="Restore from JSON…" Width="180" Padding="0,7"
                HorizontalAlignment="Left"
                Command="{Binding RestoreFromJsonCommand}"
                ToolTip="Replace the canonical JSON files with files you choose" />

        <!-- Status bar -->
        <Border Margin="0,24,0,0" Background="#F0F4F8" BorderBrush="#D0D8E0"
                BorderThickness="1" CornerRadius="3" Padding="12,8">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="#333" TextWrapping="Wrap" />
        </Border>

    </StackPanel>
</UserControl>
