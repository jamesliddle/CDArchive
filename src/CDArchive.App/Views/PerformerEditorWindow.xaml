<Window x:Class="CDArchive.App.Views.PerformerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performer"
        Width="400" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <DockPanel Margin="15">

        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6" Margin="8,0,0,0"
                    IsCancel="True" />
        </StackPanel>

        <!-- Fields -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"
                       VerticalAlignment="Center" Margin="0,0,8,10" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox"
                     FontSize="13" Padding="4,3" Margin="0,0,0,10" />

            <!-- Role -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Role:"
                       VerticalAlignment="Center" Margin="0,0,8,10" />
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="RoleBox"
                      IsEditable="True" FontSize="13" Margin="0,0,0,10" />

            <!-- Instrument -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Instrument:"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="InstrumentBox"
                     FontSize="13" Padding="4,3" />

        </Grid>
    </DockPanel>
</Window>
