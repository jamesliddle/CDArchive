<Window x:Class="CDArchive.App.Views.PiecesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CDArchive.Core.Models;assembly=CDArchive.Core"
        Title="Pieces" Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </Window.Resources>

    <DockPanel Margin="8">
        <!-- Toolbar: Filter + New Piece + Delete Piece -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button x:Name="DeletePieceButton" Content="Delete Piece" DockPanel.Dock="Right"
                    Padding="12,4" Margin="8,0,0,0" FontSize="12"
                    IsEnabled="False"
                    Click="OnDeletePieceClick" />
            <Button Content="New Piece" DockPanel.Dock="Right"
                    Padding="12,4" Margin="8,0,0,0" FontSize="12"
                    Click="OnNewPieceClick" />
            <TextBlock Text="Filter:" VerticalAlignment="Center"
                       Margin="0,0,8,0" FontSize="12" Foreground="#555" />
            <TextBox x:Name="FilterBox" FontSize="13" Padding="6,4"
                     TextChanged="OnFilterChanged" />
        </DockPanel>

        <!-- Close button at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Close" Width="80" Padding="0,6"
                    IsCancel="True" Click="OnCloseClick" />
        </StackPanel>

        <!-- Resizable column header + TreeView -->
        <Border BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
            <DockPanel>
                <!-- Column headers with GridSplitters for resizing -->
                <Grid DockPanel.Dock="Top" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="19" />
                        <ColumnDefinition Width="450" MinWidth="80" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="80"  MinWidth="40" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="90"  MinWidth="40" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="55"  MinWidth="35" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" x:Name="HdrExpander" />
                    <Border Grid.Column="1" x:Name="HdrTitle" Cursor="Hand"
                            Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                            Tag="Title">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Title" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock x:Name="SortTitle" FontSize="10" Margin="4,0,0,0"
                                       Foreground="#999" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <GridSplitter Grid.Column="2" Width="4" Background="Transparent"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Cursor="SizeWE" />
                    <Border Grid.Column="3" x:Name="HdrCatalog" Cursor="Hand"
                            Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                            Tag="Catalog">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Catalogue" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock x:Name="SortCatalog" FontSize="10" Margin="4,0,0,0"
                                       Foreground="#999" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <GridSplitter Grid.Column="4" Width="4" Background="Transparent"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Cursor="SizeWE" />
                    <Border Grid.Column="5" x:Name="HdrCategory" Cursor="Hand"
                            Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                            Tag="Category">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Category" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock x:Name="SortCategory" FontSize="10" Margin="4,0,0,0"
                                       Foreground="#999" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <GridSplitter Grid.Column="6" Width="4" Background="Transparent"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Cursor="SizeWE" />
                    <Border Grid.Column="7" x:Name="HdrYear" Cursor="Hand"
                            Background="Transparent" MouseLeftButtonUp="OnColumnHeaderClick"
                            Tag="Year">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Year" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock x:Name="SortYear" FontSize="10" Margin="4,0,0,0"
                                       Foreground="#999" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
                <Border DockPanel.Dock="Top" BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1" Margin="0,0,0,2" />

                <!-- TreeView -->
                <TreeView x:Name="PiecesTree"
                          BorderThickness="0" Background="White" Padding="0"
                          FontSize="12"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          SelectedItemChanged="OnTreeSelectionChanged"
                          KeyDown="OnTreeKeyDown">
                    <TreeView.Template>
                        <ControlTemplate TargetType="TreeView">
                            <ScrollViewer Focusable="False"
                                          CanContentScroll="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="0">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </TreeView.Template>
                    <TreeView.Resources>
                        <!-- Expander triangle style -->
                        <Style x:Key="ExpanderToggle" TargetType="ToggleButton">
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Width" Value="16" />
                            <Setter Property="Height" Value="16" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="3">
                                            <Path x:Name="Arrow"
                                                  Data="M 0,0 L 6,4 L 0,8 Z"
                                                  Fill="#888" HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow"
                                                        Property="Data"
                                                        Value="M 0,0 L 8,0 L 4,6 Z" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <!-- Custom TreeViewItem -->
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeViewItem">
                                        <StackPanel>
                                            <Border x:Name="Bd" Background="Transparent"
                                                    Padding="0,1">
                                                <ContentPresenter ContentSource="Header" />
                                            </Border>
                                            <ItemsPresenter x:Name="ItemsHost"
                                                            Margin="19,0,0,0"
                                                            Visibility="Collapsed" />
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ItemsHost"
                                                        Property="Visibility" Value="Visible" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Background" Value="#E8F0FE" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Background" Value="#F0F0F0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <EventSetter Event="MouseDoubleClick" Handler="OnPieceDoubleClick" />
                        </Style>

                        <!-- Template for top-level pieces and subpiece movements -->
                        <HierarchicalDataTemplate
                            DataType="{x:Type local:CanonPiece}"
                            ItemsSource="{Binding TreeChildren}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Border Width="{Binding ActualWidth, ElementName=HdrExpander}">
                                    <ToggleButton
                                        Style="{StaticResource ExpanderToggle}"
                                        IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                        Visibility="{Binding HasTreeChildren,
                                            Converter={StaticResource BoolToVisConverter}}" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrTitle}">
                                    <TextBlock Text="{Binding DisplayTitleShort}"
                                               Foreground="#333" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="600">
                                                <TextBlock Text="{Binding ToolTipText}"
                                                           TextWrapping="Wrap" FontSize="13" />
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrCatalog}">
                                    <TextBlock Text="{Binding Catalog}"
                                               Foreground="#555" VerticalAlignment="Center" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrCategory}">
                                    <TextBlock Text="{Binding Category}"
                                               Foreground="#555" VerticalAlignment="Center" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrYear}">
                                    <TextBlock Text="{Binding PublicationYear}"
                                               Foreground="#555" VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <!-- Template for subpiece (movement) nodes -->
                        <HierarchicalDataTemplate
                            DataType="{x:Type local:SubpieceDisplayNode}"
                            ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Border Width="{Binding ActualWidth, ElementName=HdrExpander}">
                                    <ToggleButton
                                        Style="{StaticResource ExpanderToggle}"
                                        IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                        Visibility="{Binding HasChildren,
                                            Converter={StaticResource BoolToVisConverter}}" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrTitle}">
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               Foreground="#444"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="600">
                                                <TextBlock Text="{Binding Piece.ToolTipText}"
                                                           TextWrapping="Wrap" FontSize="13" />
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrCatalog}">
                                    <TextBlock Text="{Binding Piece.Catalog}"
                                               Foreground="#666" VerticalAlignment="Center" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrCategory}">
                                    <TextBlock Text="{Binding Piece.Category}"
                                               Foreground="#666" VerticalAlignment="Center" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrYear}">
                                    <TextBlock Text="{Binding Piece.PublicationYear}"
                                               Foreground="#666" VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <!-- Template for version nodes (intermediate level between piece and movements) -->
                        <HierarchicalDataTemplate
                            DataType="{x:Type local:VersionDisplayNode}"
                            ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Border Width="{Binding ActualWidth, ElementName=HdrExpander}">
                                    <ToggleButton
                                        Style="{StaticResource ExpanderToggle}"
                                        IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                        Visibility="{Binding HasSubpieces,
                                            Converter={StaticResource BoolToVisConverter}}" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrTitle}">
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               Foreground="#666" FontStyle="Italic"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrCatalog}" />
                                <Border Width="{Binding ActualWidth, ElementName=HdrCategory}">
                                    <TextBlock Text="{Binding Version.InstrumentationCategory}"
                                               Foreground="#888" VerticalAlignment="Center" />
                                </Border>
                                <Border Width="{Binding ActualWidth, ElementName=HdrYear}">
                                    <TextBlock Text="{Binding Version.PublicationYear}"
                                               Foreground="#888" VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
