<Window x:Class="CDArchive.App.Views.ComposerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Composer" Width="480" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6"
                    Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>

        <!-- Form fields -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
          <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Name" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="NameBox" />

                <TextBlock Grid.Row="1" Text="Sort Name" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="SortNameBox" />

                <TextBlock Grid.Row="2" Text="Birth Date" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="BirthDateBox" Width="120" HorizontalAlignment="Left" />

                <TextBlock Grid.Row="3" Text="Birth Place" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="BirthPlaceBox" />

                <TextBlock Grid.Row="4" Text="Birth State" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="BirthStateBox" />

                <TextBlock Grid.Row="5" Text="Birth Country" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="5" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="BirthCountryBox" />

                <TextBlock Grid.Row="6" Text="Death Date" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="6" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="DeathDateBox" Width="120" HorizontalAlignment="Left" />

                <TextBlock Grid.Row="7" Text="Death Place" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="7" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="DeathPlaceBox" />

                <TextBlock Grid.Row="8" Text="Death State" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="8" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="DeathStateBox" />

                <TextBlock Grid.Row="9" Text="Death Country" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="9" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="DeathCountryBox" />

                <TextBlock Grid.Row="10" Text="Notes" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Top" Margin="0,6,8,0" />
                <TextBox   Grid.Row="10" Grid.Column="1" x:Name="NotesBox"
                           FontSize="13" Padding="4,3" Margin="0,3"
                           AcceptsReturn="True" TextWrapping="Wrap"
                           Height="60" VerticalScrollBarVisibility="Auto" />
            </Grid>

            <!-- Aliases / AKAs section -->
            <TextBlock Text="Aliases / AKAs" FontWeight="SemiBold" FontSize="12"
                       Foreground="#555" Margin="0,14,0,6" />

            <Border BorderThickness="1" BorderBrush="#D0D0D0" Background="#FAFAFA" Padding="6">
                <StackPanel>
                    <DockPanel MinHeight="20" MaxHeight="80">
                        <Button DockPanel.Dock="Right" Content="✕" Padding="6,3" FontSize="11"
                                VerticalAlignment="Top" Margin="2"
                                ToolTip="Remove selected alias"
                                Click="OnRemoveAliasClick" />
                        <ListBox x:Name="AliasList" FontSize="12" BorderThickness="0" />
                    </DockPanel>
                    <Border BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" />
                    <DockPanel Margin="4,4,4,4">
                        <Button DockPanel.Dock="Right" Content="Add" Padding="8,3" FontSize="11"
                                Margin="4,0,0,0" Click="OnAddAliasClick" />
                        <TextBox x:Name="AliasEntryBox" FontSize="12" Padding="3,2"
                                 ToolTip="Alternative name, nickname, or maiden name" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Catalogues section -->
            <TextBlock Text="Catalogues" FontWeight="SemiBold" FontSize="12"
                       Foreground="#555" Margin="0,14,0,6" />
            <TextBlock Text="Restrict the catalogue prefixes available when editing this composer's pieces. Leave empty to allow all prefixes."
                       FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,4" />

            <Border BorderThickness="1" BorderBrush="#D0D0D0" Background="#FAFAFA" Padding="6">
                <StackPanel>
                    <DockPanel MinHeight="20" MaxHeight="80">
                        <Button DockPanel.Dock="Right" Content="✕" Padding="6,3" FontSize="11"
                                VerticalAlignment="Top" Margin="2"
                                ToolTip="Remove selected prefix"
                                Click="OnRemoveCatalogClick" />
                        <ListBox x:Name="CatalogList" FontSize="12" BorderThickness="0" />
                    </DockPanel>
                    <Border BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" />
                    <DockPanel Margin="4,4,4,4">
                        <Button DockPanel.Dock="Right" Content="Add" Padding="8,3" FontSize="11"
                                Margin="4,0,0,0" Click="OnAddCatalogClick" />
                        <ComboBox x:Name="CatalogPrefixCombo" IsEditable="True"
                                  FontSize="12" Padding="3,2" />
                    </DockPanel>
                </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
