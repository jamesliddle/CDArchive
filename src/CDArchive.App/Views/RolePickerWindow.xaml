<Window x:Class="CDArchive.App.Views.RolePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Roles" Width="380" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6"
                    Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="Select one or more roles from the cast:"
                   FontSize="12" Foreground="#555" Margin="0,0,0,8" />

        <ListBox x:Name="RoleList"
                 SelectionMode="Extended"
                 FontSize="12"
                 BorderThickness="1" BorderBrush="#CCC" />
    </DockPanel>
</Window>
