<Window x:Class="CDArchive.App.Views.PickListEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Pick Lists" Width="1000" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6"
                    Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>

        <!-- Four lists side by side -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="0.7*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="0.7*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="0.7*" />
            </Grid.ColumnDefinitions>

            <!-- Forms -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Forms" FontWeight="SemiBold"
                           FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                    <TextBox x:Name="FormTextBox" FontSize="12" Padding="3,2"
                             VerticalContentAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Button Content="Add" Padding="8,3" Click="OnAddForm" />
                        <Button Content="Update" Padding="8,3" Margin="4,0,0,0"
                                Click="OnUpdateForm" />
                        <Button Content="Remove" Padding="8,3" Margin="4,0,0,0"
                                Click="OnRemoveForm" />
                    </StackPanel>
                </StackPanel>
                <ListBox x:Name="FormsList" FontSize="12"
                         SelectionChanged="OnFormsSelectionChanged" />
            </DockPanel>

            <!-- Categories -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Categories" FontWeight="SemiBold"
                           FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                    <TextBox x:Name="CategoryTextBox" FontSize="12" Padding="3,2"
                             VerticalContentAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Button Content="Add" Padding="8,3" Click="OnAddCategory" />
                        <Button Content="Update" Padding="8,3" Margin="4,0,0,0"
                                Click="OnUpdateCategory" />
                        <Button Content="Remove" Padding="8,3" Margin="4,0,0,0"
                                Click="OnRemoveCategory" />
                    </StackPanel>
                </StackPanel>
                <ListBox x:Name="CategoriesList" FontSize="12"
                         SelectionChanged="OnCategoriesSelectionChanged" />
            </DockPanel>

            <!-- Catalogue Prefixes -->
            <DockPanel Grid.Column="4">
                <TextBlock DockPanel.Dock="Top" Text="Catalogues" FontWeight="SemiBold"
                           FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                    <TextBox x:Name="CatalogTextBox" FontSize="12" Padding="3,2"
                             VerticalContentAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Button Content="Add" Padding="8,3" Click="OnAddCatalog" />
                        <Button Content="Update" Padding="8,3" Margin="4,0,0,0"
                                Click="OnUpdateCatalog" />
                        <Button Content="Remove" Padding="8,3" Margin="4,0,0,0"
                                Click="OnRemoveCatalog" />
                    </StackPanel>
                </StackPanel>
                <ListBox x:Name="CatalogsList" FontSize="12"
                         SelectionChanged="OnCatalogsSelectionChanged" />
            </DockPanel>

            <!-- Key Tonalities -->
            <DockPanel Grid.Column="6">
                <TextBlock DockPanel.Dock="Top" Text="Keys" FontWeight="SemiBold"
                           FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                    <TextBox x:Name="KeyTextBox" FontSize="12" Padding="3,2"
                             VerticalContentAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Button Content="Add" Padding="8,3" Click="OnAddKey" />
                        <Button Content="Update" Padding="8,3" Margin="4,0,0,0"
                                Click="OnUpdateKey" />
                        <Button Content="Remove" Padding="8,3" Margin="4,0,0,0"
                                Click="OnRemoveKey" />
                    </StackPanel>
                </StackPanel>
                <ListBox x:Name="KeysList" FontSize="12"
                         SelectionChanged="OnKeysSelectionChanged" />
            </DockPanel>
            <!-- Instruments -->
            <DockPanel Grid.Column="8">
                <TextBlock DockPanel.Dock="Top" Text="Instruments" FontWeight="SemiBold"
                           FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                    <TextBox x:Name="InstrumentTextBox" FontSize="12" Padding="3,2"
                             VerticalContentAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Button Content="Add" Padding="8,3" Click="OnAddInstrument" />
                        <Button Content="Update" Padding="8,3" Margin="4,0,0,0"
                                Click="OnUpdateInstrument" />
                        <Button Content="Remove" Padding="8,3" Margin="4,0,0,0"
                                Click="OnRemoveInstrument" />
                    </StackPanel>
                </StackPanel>
                <ListBox x:Name="InstrumentsList" FontSize="12"
                         SelectionChanged="OnInstrumentsSelectionChanged" />
            </DockPanel>

            <!-- Creative Roles -->
            <DockPanel Grid.Column="10">
                <TextBlock DockPanel.Dock="Top" Text="Creative Roles" FontWeight="SemiBold"
                           FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                    <TextBox x:Name="CreativeRoleTextBox" FontSize="12" Padding="3,2"
                             VerticalContentAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Button Content="Add" Padding="8,3" Click="OnAddCreativeRole" />
                        <Button Content="Update" Padding="8,3" Margin="4,0,0,0"
                                Click="OnUpdateCreativeRole" />
                        <Button Content="Remove" Padding="8,3" Margin="4,0,0,0"
                                Click="OnRemoveCreativeRole" />
                    </StackPanel>
                </StackPanel>
                <ListBox x:Name="CreativeRolesList" FontSize="12"
                         SelectionChanged="OnCreativeRolesSelectionChanged" />
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
