<Window x:Class="CDArchive.App.Views.MovementEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Movement" Width="520" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="IsEditable" Value="True" />
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="0,6"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Padding="0,6"
                    Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
          <StackPanel>
            <!-- Movement fields -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Number" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="NumberBox" Width="60" HorizontalAlignment="Left" />

                <TextBlock Grid.Row="1" Text="Form" Style="{StaticResource FieldLabel}" />
                <ComboBox  Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldCombo}"
                           x:Name="FormCombo" />

                <TextBlock Grid.Row="2" Text="Title" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="TitleBox" />

                <TextBlock Grid.Row="3" Text="Nickname" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="NicknameBox" />

                <TextBlock Grid.Row="4" Text="Key Tonality" Style="{StaticResource FieldLabel}" />
                <ComboBox  Grid.Row="4" Grid.Column="1" Style="{StaticResource FieldCombo}"
                           x:Name="KeyTonalityCombo" Width="120" HorizontalAlignment="Left" />

                <TextBlock Grid.Row="5" Text="Key Mode" Style="{StaticResource FieldLabel}" />
                <ComboBox  Grid.Row="5" Grid.Column="1" Width="120" HorizontalAlignment="Left"
                           Margin="0,3" Padding="4,4" FontSize="13"
                           x:Name="KeyModeCombo">
                    <ComboBoxItem Content="" />
                    <ComboBoxItem Content="major" />
                    <ComboBoxItem Content="minor" />
                </ComboBox>

                <TextBlock Grid.Row="6" Text="Name" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="6" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="NameBox"
                           ToolTip="Section or act name, e.g. Act I, Scena prima" />

                <TextBlock Grid.Row="7" Text="First Line" Style="{StaticResource FieldLabel}" />
                <TextBox   Grid.Row="7" Grid.Column="1" Style="{StaticResource FieldBox}"
                           x:Name="FirstLineBox"
                           ToolTip="Opening line of text for vocal numbers" />

                <!-- Roles — list of character names -->
                <TextBlock Grid.Row="8" Text="Roles" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Top" Margin="0,6,8,0" />
                <Border Grid.Row="8" Grid.Column="1" Margin="0,3"
                        BorderThickness="1" BorderBrush="#CCC">
                    <StackPanel>
                        <DockPanel MinHeight="20" MaxHeight="72">
                            <Button DockPanel.Dock="Right" Content="✕" Padding="6,3" FontSize="11"
                                    VerticalAlignment="Top" Margin="2"
                                    ToolTip="Remove selected role"
                                    Click="OnRemoveRoleClick" />
                            <ListBox x:Name="RoleList" FontSize="12" BorderThickness="0" />
                        </DockPanel>
                        <Border BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" />
                        <DockPanel Margin="4,4,4,4">
                            <Button DockPanel.Dock="Right" Content="Add" Padding="8,3" FontSize="11"
                                    Margin="4,0,0,0" Click="OnAddRoleClick" />
                            <TextBox x:Name="RoleEntryBox" FontSize="12" Padding="4,3"
                                     ToolTip="Type a character name and click Add" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tempos section -->
            <TextBlock Text="Tempo Indications" FontWeight="SemiBold" FontSize="12"
                       Foreground="#555" Margin="0,14,0,6" />

            <Border BorderThickness="1" BorderBrush="#D0D0D0" Background="#FAFAFA"
                    Padding="6" MinHeight="80">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Margin="6,0,0,0">
                        <Button Content="Add" Style="{StaticResource SmallBtn}"
                                Margin="4,0,0,0" Click="OnAddTempoClick" />
                        <Button Content="Edit" Style="{StaticResource SmallBtn}"
                                Margin="4,4,0,0" Click="OnEditTempoClick" />
                        <Button Content="Remove" Style="{StaticResource SmallBtn}"
                                Margin="4,4,0,0" Click="OnRemoveTempoClick" />
                        <Border Height="8" />
                        <Button Content="Up" Style="{StaticResource SmallBtn}"
                                Margin="4,0,0,0" Click="OnMoveTempoUpClick" />
                        <Button Content="Down" Style="{StaticResource SmallBtn}"
                                Margin="4,4,0,0" Click="OnMoveTempoDownClick" />
                    </StackPanel>
                    <ListBox x:Name="TempoList" FontSize="12" MinHeight="60"
                             BorderThickness="1" BorderBrush="#CCC"
                             MouseDoubleClick="OnTempoDoubleClick" />
                </DockPanel>
            </Border>

            <!-- Sub-movements section -->
            <TextBlock Text="Sub-movements" FontWeight="SemiBold" FontSize="12"
                       Foreground="#555" Margin="0,14,0,6" />

            <Border BorderThickness="1" BorderBrush="#D0D0D0" Background="#FAFAFA"
                    Padding="6" MinHeight="80">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Margin="6,0,0,0">
                        <Button Content="Add"    Style="{StaticResource SmallBtn}"
                                Margin="4,0,0,0" Click="OnAddSubpieceClick" />
                        <Button Content="Edit"   Style="{StaticResource SmallBtn}"
                                Margin="4,4,0,0" Click="OnEditSubpieceClick" />
                        <Button Content="Remove" Style="{StaticResource SmallBtn}"
                                Margin="4,4,0,0" Click="OnRemoveSubpieceClick" />
                        <Border Height="8" />
                        <Button Content="Up"     Style="{StaticResource SmallBtn}"
                                Margin="4,0,0,0" Click="OnMoveSubpieceUpClick" />
                        <Button Content="Down"   Style="{StaticResource SmallBtn}"
                                Margin="4,4,0,0" Click="OnMoveSubpieceDownClick" />
                    </StackPanel>
                    <ListBox x:Name="SubpieceList" FontSize="12" MinHeight="60"
                             BorderThickness="1" BorderBrush="#CCC"
                             MouseDoubleClick="OnSubpieceDoubleClick" />
                </DockPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
