<UserControl x:Class="CDArchive.App.Views.CatalogueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
             xmlns:converters="clr-namespace:CDArchive.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CatalogueViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="RuleButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#5C6BC0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Album Selection -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <DockPanel Margin="0,0,0,8">
                <Button DockPanel.Dock="Left"
                        Content="Scan Albums"
                        Command="{Binding LoadAlbumsCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,10,0" />
                <ComboBox ItemsSource="{Binding Albums}"
                          SelectedItem="{Binding SelectedAlbum}"
                          DisplayMemberPath="Name"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          Height="36" />
            </DockPanel>

            <Button Content="Load Tags"
                    Command="{Binding LoadTagsCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Bulk Edit Fields -->
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,12"
                Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Bulk Fields (applied to all tracks)"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Artist:" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BulkArtist, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Margin="4" Padding="4,3" />

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Album:" VerticalAlignment="Center" Margin="8,4,0,4" />
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding BulkAlbum, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Margin="4" Padding="4,3" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Genre:" VerticalAlignment="Center" Margin="0,4" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BulkGenre, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Margin="4" Padding="4,3" />

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Year:" VerticalAlignment="Center" Margin="8,4,0,4" />
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding BulkYear, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Margin="4" Padding="4,3" />
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Apply Bulk Fields"
                            Command="{Binding ApplyBulkFieldsCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,15,0" />

                    <TextBlock Text="Formatting Rules:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0" />
                    <Button Content="Hyphenate Keys"
                            Command="{Binding HyphenateKeysCommand}"
                            Style="{StaticResource RuleButtonStyle}"
                            ToolTip="B flat → B-flat, c sharp → c-sharp" />
                    <Button Content="Pad Movements"
                            Command="{Binding PadMovementNumbersCommand}"
                            Style="{StaticResource RuleButtonStyle}"
                            ToolTip="Auto-pads movement numbers when a work has more than 9 movements" />
                    <TextBox x:Name="MaxCatalogueCount"
                             Width="45"
                             FontSize="12"
                             Padding="4,4"
                             VerticalContentAlignment="Center"
                             ToolTip="Max works of this type in composer's catalogue" />
                    <Button Content="Pad Work #s"
                            Command="{Binding PadWorkNumbersCommand}"
                            CommandParameter="{Binding Text, ElementName=MaxCatalogueCount}"
                            Style="{StaticResource RuleButtonStyle}"
                            ToolTip="Pads #N based on catalogue size (enter max count to the left)" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status and Write -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button DockPanel.Dock="Right"
                    Content="Write Tags"
                    Command="{Binding WriteTagsCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="10,0,0,0"
                    Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="#555555"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Track Grid -->
        <DataGrid ItemsSource="{Binding Entries}"
                  SelectedItem="{Binding SelectedEntry}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  FontSize="13"
                  CanUserSortColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding TrackNumber}"
                                    Width="35"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Composer"
                                    Binding="{Binding Composer}"
                                    Width="200" />
                <DataGridTextColumn Header="Artist"
                                    Binding="{Binding Artist}"
                                    Width="200" />
                <DataGridTextColumn Header="Genre"
                                    Binding="{Binding Genre}"
                                    Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
