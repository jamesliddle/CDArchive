<UserControl x:Class="CDArchive.App.Views.PickListsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PickListsViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <DockPanel MaxWidth="480" HorizontalAlignment="Left">

        <!-- Selector row -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Pick List:" VerticalAlignment="Center"
                       FontSize="13" Foreground="#555" Margin="0,0,10,0" />
            <ComboBox FontSize="13" Width="200"
                      ItemsSource="{x:Static vm:PickListsViewModel.PickListNames}"
                      SelectedIndex="{Binding SelectedListIndex}" />
        </StackPanel>

        <!-- Save button + status at bottom -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Button DockPanel.Dock="Left" Content="Save" Width="80" Padding="0,6"
                    Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                       FontSize="12" Foreground="#555" Margin="12,0,0,0"
                       TextWrapping="Wrap" />
        </DockPanel>

        <!-- Edit controls: TextBox + buttons row above list -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBox x:Name="EditBox" FontSize="13" Padding="4,4"
                     Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Add" Width="70" Padding="0,5"
                        Command="{Binding AddItemCommand}" />
                <Button Content="Update" Width="70" Padding="0,5" Margin="6,0,0,0"
                        Command="{Binding UpdateItemCommand}" />
                <Button Content="Remove" Width="70" Padding="0,5" Margin="6,0,0,0"
                        Command="{Binding RemoveItemCommand}" />
                <!-- Members button: visible only for Ensembles list -->
                <Button x:Name="MembersButton" Content="Members…" Padding="10,5"
                        Margin="12,0,0,0"
                        Visibility="{Binding IsEnsembleList,
                                     Converter={StaticResource BoolToVis}}"
                        Click="OnMembersClick" />
            </StackPanel>
        </StackPanel>

        <!-- Values list (fills remaining space) -->
        <ListBox FontSize="13"
                 ItemsSource="{Binding CurrentItems}"
                 SelectedIndex="{Binding SelectedItemIndex}" />

    </DockPanel>
</UserControl>
