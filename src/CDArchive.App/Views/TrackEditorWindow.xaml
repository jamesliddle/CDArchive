<Window x:Class="CDArchive.App.Views.TrackEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Track"
        Width="560" Height="560"
        MinWidth="420" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <DockPanel Margin="12">

        <!-- Navigation (left) + OK/Cancel (right) -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <StackPanel x:Name="NavigationPanel"
                        DockPanel.Dock="Left" Orientation="Horizontal">
                <Button x:Name="PrevButton" Content="◀" Width="32" Padding="0,6"
                        IsEnabled="False" Click="OnPrevClick"
                        ToolTip="Previous track — saves current changes" />
                <Button x:Name="NextButton" Content="▶" Width="32" Padding="0,6"
                        Margin="4,0,0,0" Click="OnNextClick"
                        ToolTip="Next track — saves current changes" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="OkButton" Content="OK" Width="80" Padding="0,6"
                        IsDefault="True" Click="OnOkClick" />
                <Button Content="Cancel" Width="80" Padding="0,6" Margin="8,0,0,0"
                        IsCancel="True" />
            </StackPanel>
        </DockPanel>

        <!-- Main scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Track Info -->
                <GroupBox Header="Track Info" Margin="0,0,0,10" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Track Number -->
                        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="TrackNumberLabel"
                                   Text="Track #:"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TrackNumberBox"
                                 Width="60" HorizontalAlignment="Left"
                                 FontSize="13" Padding="4,3" Margin="0,0,0,8" />

                        <!-- Duration -->
                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="DurationLabel"
                                   Text="Duration:"
                                   VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="DurationBox"
                                 Width="100" HorizontalAlignment="Left"
                                 FontSize="13" Padding="4,3" Margin="0,0,0,8"
                                 ToolTip="e.g. 5:32 or 1:02:15" />

                        <!-- SPARS Code -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SPARS Code:"
                                   VerticalAlignment="Center" Margin="0,0,8,8"
                                   ToolTip="Overrides the album-level SPARS code for this track" />
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="TrackSparsCodeBox"
                                  IsEditable="True" Width="100" HorizontalAlignment="Left"
                                  FontSize="13" Margin="0,0,0,8"
                                  ToolTip="D=digital, A=analogue: recording / mixing / mastering. Leave blank to inherit the album SPARS code.">
                            <ComboBoxItem Content="DDD" />
                            <ComboBoxItem Content="ADD" />
                            <ComboBoxItem Content="AAD" />
                            <ComboBoxItem Content="Unknown" />
                        </ComboBox>

                        <!-- Session: dropdown + Add button on the same row -->
                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="SessionLabel"
                                   Text="Session:"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <DockPanel Grid.Row="3" Grid.Column="1" x:Name="SessionPanel">
                            <Button DockPanel.Dock="Right" Content="Add…"
                                    Padding="8,3" Margin="6,0,0,0"
                                    Click="OnAddSession" />
                            <ComboBox x:Name="SessionBox" FontSize="13" />
                        </DockPanel>

                    </Grid>
                </GroupBox>

                <!-- Description -->
                <GroupBox Header="Description" Margin="0,0,0,10" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Used for tracks not linked to the Canon (e.g. 'Interview with Brendel')"
                                   FontSize="11" Foreground="#888" TextWrapping="Wrap"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="DescriptionBox" Height="50"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 FontSize="13" Padding="4,3" />
                    </StackPanel>
                </GroupBox>

                <!-- Piece References -->
                <GroupBox x:Name="PieceRefsGroup" Header="Piece References" Padding="8">
                    <DockPanel>
                        <TextBlock x:Name="PieceRefsMixedNote"
                                   DockPanel.Dock="Top"
                                   Text="Mixed — values differ across selected tracks. Add or remove any entry to replace the list for all selected tracks."
                                   Foreground="DarkGray" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,0,0,6"
                                   Visibility="Collapsed" />
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <Button x:Name="AddPieceRefButton" Content="Add"
                                    Padding="10,4" Click="OnAddPieceRef" />
                            <Button x:Name="RemovePieceRefButton" Content="Remove"
                                    Padding="10,4" Margin="6,0,0,0"
                                    IsEnabled="False" Click="OnRemovePieceRef" />
                        </StackPanel>
                        <ListBox x:Name="PieceRefList" MinHeight="80" MaxHeight="160"
                                 BorderThickness="1" BorderBrush="#CCC" Margin="0,6,0,0"
                                 SelectionChanged="OnPieceRefSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplaySummary}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </GroupBox>

                <!-- Performer Override -->
                <GroupBox x:Name="PerformerOverrideGroup"
                          Header="Performer Override" Margin="0,10,0,0" Padding="8">
                    <StackPanel>
                        <CheckBox x:Name="OverridePerformersCheck"
                                  Content="Override album-level performers for this track"
                                  Checked="OnOverrideCheckChanged"
                                  Unchecked="OnOverrideCheckChanged"
                                  Indeterminate="OnOverrideCheckChanged" />
                        <TextBlock x:Name="PerformerMixedNote"
                                   Text="Mixed — override state and/or performer lists differ across selected tracks. Toggle the checkbox or edit the list to apply the same value to all."
                                   Foreground="DarkGray" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                   Visibility="Collapsed" />
                        <StackPanel x:Name="PerformerOverridePanel"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                            <DockPanel Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Add" Padding="10,4"
                                            Click="OnAddTrackPerformer" />
                                    <Button x:Name="RemoveTrackPerformerButton" Content="Remove"
                                            Padding="10,4" Margin="6,0,0,0"
                                            IsEnabled="False" Click="OnRemoveTrackPerformer" />
                                </StackPanel>
                            </DockPanel>
                            <ListBox x:Name="TrackPerformerList" MinHeight="60" MaxHeight="120"
                                     BorderThickness="1" BorderBrush="#CCC" Margin="0,6,0,0"
                                     SelectionChanged="OnTrackPerformerSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
