<Window x:Class="CDArchive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CDArchive.App.ViewModels"
        xmlns:views="clr-namespace:CDArchive.App.Views"
        mc:Ignorable="d"
        Title="CD Archive Manager"
        Height="700" Width="1120"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Navigation RadioButton Style -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="Navigation" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BorderElement"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderElement" Property="Background" Value="#3E3E42" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BorderElement" Property="Background" Value="#3E3E42" />
                                <Setter TargetName="BorderElement" Property="BorderBrush" Value="#007ACC" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Left Navigation Panel -->
        <Border DockPanel.Dock="Left" Width="200" Background="#2D2D30">
            <DockPanel>
                <!-- App Title -->
                <TextBlock DockPanel.Dock="Top"
                           Text="CD Archive"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="20,20,20,25"
                           HorizontalAlignment="Center" />

                <Separator DockPanel.Dock="Top"
                           Background="#444448"
                           Margin="15,0,15,10" />

                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Top">
                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Composers and Authors"
                                 IsChecked="True"
                                 Command="{Binding NavigateToCanonCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="New Album"
                                 Command="{Binding NavigateToNewAlbumCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Browse Archive"
                                 Command="{Binding NavigateToArchiveBrowserCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Validate Archive"
                                 Command="{Binding NavigateToValidationCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Convert to MP3"
                                 Command="{Binding NavigateToConversionCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Conversion Status"
                                 Command="{Binding NavigateToConversionStatusCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Catalogue"
                                 Command="{Binding NavigateToCatalogueCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Import / Export"
                                 Command="{Binding NavigateToImportExportCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Pick Lists"
                                 Command="{Binding NavigateToPickListsCommand}" />

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Content="Settings"
                                 Command="{Binding NavigateToSettingsCommand}" />
                </StackPanel>

                <!-- Spacer -->
                <Border />
            </DockPanel>
        </Border>

        <!-- Right Content Area -->
        <Border Background="#F5F5F5">
            <DockPanel Margin="0">
                <!-- View Title Header -->
                <Border DockPanel.Dock="Top"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="25,15">
                    <TextBlock Text="{Binding CurrentViewTitle}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#333333" />
                </Border>

                <!-- Content area: CanonView lives permanently; other views use ContentControl -->
                <Grid Margin="25,20">
                    <!-- CanonView is always alive — shown/hidden without being destroyed.
                         DataContext is CanonViewModel, so Visibility must reach back up to
                         the Window's DataContext (MainViewModel) via RelativeSource. -->
                    <views:CanonView DataContext="{Binding CanonViewModel}"
                                     Visibility="{Binding DataContext.IsCanonViewActive,
                                                  RelativeSource={RelativeSource AncestorType=Window},
                                                  Converter={StaticResource BoolToVis}}" />

                    <!-- Other views: CurrentView=null when Composers is active, so this is empty/non-blocking -->
                    <ContentControl Content="{Binding CurrentView}" />
                </Grid>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
